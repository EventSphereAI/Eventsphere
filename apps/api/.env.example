# ── Database ─────────────────────────────────────────────────
# Get this from: Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# QR code signing secret (keep private — changing this invalidates all QR codes)
QR_HMAC_SECRET=your-qr-signing-secret

# ── Platform ──────────────────────────────────────────────────
PLATFORM_DOMAIN=eventsphere.app
SUPER_ADMIN_SECRET=your-super-admin-header-secret

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@eventsphere.app

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Storage (Cloudflare R2 / Supabase) ────────────────────────
STORAGE_BUCKET=eventsphere-files
STORAGE_URL=https://your-account.r2.cloudflarestorage.com

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
